# LiveKit Cloud credentials (get from https://cloud.livekit.io)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# OpenAI (for LLM + embeddings)
OPENAI_API_KEY=sk-...

# Google Places API (for grocery store tool call)
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=your_google_api_key

# Deepgram (for STT - optional if using LiveKit Inference)
# DEEPGRAM_API_KEY=your_deepgram_key

# Cartesia (for TTS - optional if using LiveKit Inference)
# CARTESIA_API_KEY=your_cartesia_key
